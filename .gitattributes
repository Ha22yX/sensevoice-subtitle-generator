# Normalize text files to LF across platforms.
* text=auto eol=lf

# Keep Windows scripts on CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files.
*.onnx binary
*.tar.bz2 binary
*.wav binary
*.mp3 binary
*.mp4 binary
*.mkv binary
*.mov binary
*.png binary
*.jpg binary
*.jpeg binary
*.icns binary
